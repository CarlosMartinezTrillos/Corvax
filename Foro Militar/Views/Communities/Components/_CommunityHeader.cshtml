@model Foro.API.DTOs.Community.CommunityDashboardDto

<div class="cvx-comm-main">

    <!-- ICONO DE LA COMUNIDAD -->
    <div class="cvx-comm-icon">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Name" />
        }
        else
        {
            <i class="fa-solid fa-crow"></i>
        }
    </div>

    <div class="cvx-comm-meta">

        <!-- TITULO + ACCIONES -->
        <div class="cvx-comm-title-row">

            <h1 class="cvx-comm-name">
                <i class="fa-solid fa-users"></i>
                @Model.Name
            </h1>

            <div class="cvx-comm-actions">

                <!-- 1. RANGO -->
                <div class="cvx-rank-cluster">

                    @if (Model.IsDominant)
                    {
                        <span class="cvx-badge-dominant">
                            <i class="fa-solid fa-crown"></i>
                        </span>
                    }

                    <span class="cvx-rank-name">
                        <i class="fa-solid fa-shield"></i>
                        @(!string.IsNullOrEmpty(Model.RankName) ? Model.RankName : "Recluta")
                    </span>

                    @if (Model.RankPosition.HasValue)
                    {
                        <span class="cvx-rank-position">#@Model.RankPosition</span>
                    }
                </div>

                <!-- 2. BANDERA -->
                <div class="cvx-country-flag">
                    <i class="fa-solid fa-flag"></i>
                    @(!string.IsNullOrEmpty(Model.Country) ? Model.Country : "Global")
                </div>

                <!-- 3. COMPARTIR -->
                <button class="cvx-btn-outline"
                        onclick="CorvaxDashboard.share('@Model.Slug')">
                    <i class="fa-solid fa-share-nodes"></i>
                    <span>Compartir</span>
                </button>

                <!-- 4. SEGUIR / EDITAR -->
                @if (Model.IsOwner || Model.IsModerator)
                {
                    <a href="@Url.Action("Edit", "Community", new { slug = Model.Slug })"
                       class="cvx-btn-outline">
                        <i class="fa-solid fa-gear"></i>
                        <span>Editar comunidad</span>
                    </a>
                }
                else
                {
                    <button class="cvx-btn-follow @(Model.IsFollowing ? "is-following" : "")"
                            data-community-id="@Model.Id"
                            data-action="@Url.Action("ToggleFollow", "CommunityDashboard", new { id = Model.Id })">
                        @if (Model.IsFollowing)
                        {
                            <i class="fa-solid fa-check"></i>
                            <span>Siguiendo</span>
                        }
                        else
                        {
                            <i class="fa-solid fa-plus"></i>
                            <span>Seguir</span>
                        }
                    </button>
                }

            </div>

        </div>

        @{
            var xpPct = Model.LevelProgressPercent;
            var xpWidthHeader = xpPct + "%";
            var ptsLeft = Model.PointsToNextRank.ToString("N0");
            var headerMainColor = !string.IsNullOrEmpty(Model.MainCategoryColor)
                ? Model.MainCategoryColor : "#7c3aed";
            var xpGradient = $"width:{xpWidthHeader};background:linear-gradient(90deg,{headerMainColor},#c084fc,{headerMainColor})";
        }
        <div class="cvx-xp-wrapper tooltip-container"
             style="overflow:visible; position:relative; cursor:help;">
            <div class="cvx-xp-bar" style="@xpGradient"></div>
            </div>
            <div class="tooltip-content xp-tooltip">
                <div class="xp-tooltip-row">
                    <i class="fa-solid fa-shield"></i>
                    <span>@(!string.IsNullOrEmpty(Model.RankName) ? Model.RankName : "Recluta")</span>
                </div>
                <div class="xp-tooltip-progress">
                    <span class="xp-tooltip-pct">@xpPct%</span> hacia el siguiente rango
                </div>
                <div class="xp-tooltip-points">
                    <i class="fa-solid fa-bolt"></i>
                    @ptsLeft pts para <strong>@Model.NextRankName</strong>
                </div>
                <div class="xp-tooltip-score">
                    PowerScore: @Model.PowerScore.ToString("N0")
                </div>
            </div>
        </div>


        <!-- CATEGORIAS -->
        @if (Model.CategoryStats != null && Model.CategoryStats.Any())
        {
            <div class="cvx-comm-tags">

                <i class="fa-solid fa-tags cvx-meta-icon"></i>

                @foreach (var cat in Model.CategoryStats.Take(4))
                {
                    <span class="cvx-tag" style="--tag-color:@cat.ColorHex">
                        @cat.Name
                    </span>
                }

            </div>
        }

        <!-- DESCRIPCION -->
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="cvx-comm-desc">
                <i class="fa-solid fa-circle-info"></i>
                @Model.Description
            </p>
        }

    </div>
