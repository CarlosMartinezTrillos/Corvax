@model Foro.API.DTOs.Community.CommunityDashboardDto

<div class="cvx-comm-main">

    <!-- ICONO DE LA COMUNIDAD -->
    <div class="cvx-comm-icon">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Name" />
        }
        else
        {
            <i class="fa-solid fa-crow"></i>
        }
    </div>

    <div class="cvx-comm-meta">

        <!-- TITULO + ACCIONES -->
        <div class="cvx-comm-title-row">

            <h1 class="cvx-comm-name">
                <i class="fa-solid fa-users"></i>
                @Model.Name
            </h1>

            <div class="cvx-comm-actions">

                @if (Model.IsOwner || Model.IsModerator)
                {
                    <a href="@Url.Action("Edit", "Community", new { slug = Model.Slug })"
                       class="cvx-btn-outline">

                        <i class="fa-solid fa-gear"></i>
                        <span>Editar comunidad</span>

                    </a>
                }
                else
                {
                    <button class="cvx-btn-follow @(Model.IsFollowing ? "is-following" : "")"
                            data-community-id="@Model.Id"
                            data-action="@Url.Action("ToggleFollow", "CommunityDashboard", new { id = Model.Id })">

                        @if (Model.IsFollowing)
                        {
                            <i class="fa-solid fa-check"></i>
                            <span>Siguiendo</span>
                        }
                        else
                        {
                            <i class="fa-solid fa-plus"></i>
                            <span>Seguir</span>
                        }

                    </button>
                }

                <!-- BOTON COMPARTIR -->
                <button class="cvx-btn-outline"
                        onclick="CorvaxDashboard.share('@Model.Slug')">

                    <i class="fa-solid fa-share-nodes"></i>
                    <span>Compartir</span>

                </button>

            </div>

        </div>

        <!-- CATEGORIAS -->
        @if (Model.CategoryStats != null && Model.CategoryStats.Any())
        {
            <div class="cvx-comm-tags">

                <i class="fa-solid fa-tags cvx-meta-icon"></i>

                @foreach (var cat in Model.CategoryStats.Take(4))
                {
                    <span class="cvx-tag" style="--tag-color:@cat.ColorHex">
                        @cat.Name
                    </span>
                }

            </div>
        }

        <!-- DESCRIPCION -->
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="cvx-comm-desc">
                <i class="fa-solid fa-circle-info"></i>
                @Model.Description
            </p>
        }

    </div>

</div>