@model List<Foro_Militar.Models.CommunityViewModel>

@{
    ViewBag.Title = "Comunidades";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 style="margin-bottom:40px;">Explorar Comunidades</h2>

<div class="dashboard-grid">
    @foreach (var community in Model)
    {
        @Html.Partial("_CommunityCard", community)
    }
</div>
@section scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            document.querySelectorAll(".vote-widget").forEach(widget => {

                const upBtn = widget.querySelector(".up");
                const downBtn = widget.querySelector(".down");

                const upCounter = widget.querySelector(".up-counter .vote-tier span");
                const downCounter = widget.querySelector(".down-counter span");

                function sendVote(type) {
                    const id = widget.dataset.id;

                    fetch("/Communities/VoteCommunity", {
                        method: "POST",
                        headers: { "Content-Type": "application/x-www-form-urlencoded" },
                        body: "id=" + id + "&voteType=" + type
                    })
                        .then(r => r.json())
                        .then(data => {

                            if (!data.success) return;

                            const upCounter = widget.querySelector(".up-counter");
                            const downCounter = widget.querySelector(".down-counter");

                            if (upCounter) upCounter.innerHTML = CorvaxDashboard.renderVoteTier(data.upVotes);
                            if (downCounter) downCounter.innerHTML = CorvaxDashboard.renderDownvoteTier(data.downVotes);

                            if (type === 1) {

                                if (upBtn.classList.contains("active")) {
                                    upBtn.classList.remove("active");
                                }
                                else {
                                    upBtn.classList.add("active");
                                    downBtn.classList.remove("active");
                                }

                            }

                            if (type === -1) {

                                if (downBtn.classList.contains("active")) {
                                    downBtn.classList.remove("active");
                                }
                                else {
                                    downBtn.classList.add("active");
                                    upBtn.classList.remove("active");
                                }

                            }

                        });

                }

                upBtn.addEventListener("click", () => sendVote(1));
                downBtn.addEventListener("click", () => sendVote(-1));

            });

            document.querySelectorAll(".btn-follow").forEach(btn => {
                // Inicializar estado visual
                const isFollowing = btn.dataset.following === "true";
                if (isFollowing) btn.classList.add("active");

                btn.addEventListener("click", () => {
                    const communityId = btn.dataset.id;

                    fetch("/Communities/ToggleFollowCommunity", {
                        method: "POST",
                        headers: { "Content-Type": "application/x-www-form-urlencoded" },
                        body: "communityId=" + communityId
                    })
                        .then(r => r.json())
                        .then(data => {
                            if (!data.success) return;

                            // Cambiar estado visual
                            btn.classList.toggle("active", data.isFollowing);

                            // Cambiar tooltip
                            btn.querySelector(".tooltip-content").innerText = data.isFollowing
                                ? "Dejar de seguir"
                                : "Seguir comunidad";

                            // Actualizar contador de seguidores
                            const statBox = btn.closest(".community-card-pro").querySelector(".stat-box strong");
                            statBox.innerText = data.totalFollowers;
                        });
                });
            });


        });    
    </script>
}