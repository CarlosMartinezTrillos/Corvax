@model Foro_Militar.Models.CreatePostViewModel
@{
    Layout = ViewBag.UseModalLayout == true
             ? null
             : "~/Views/Shared/_Layout.cshtml";
}
@* ── CSS solo cuando viene en modo modal (layout null) ── *@
@if (ViewBag.UseModalLayout == true)
{
    <link href="https://fonts.googleapis.com/..." rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/Content/create-post.css?v=2" />
    @* ← agregar ?v=2 aquí *@
}
else
{
    @section Styles {
        <link rel="stylesheet" href="~/Content/create-post.css?v=2" />
    }
}

@* ── campos hidden para enviar con el form ── *@
@* MainCategoryId y PostType se llenan por JS antes del submit *@

<div class="cvx-cp-wrapper">

    @if (ViewBag.UseModalLayout != true)
    {
        <a href="@Url.Action("Dashboard", "Communities", new { slug = Model.CommunitySlug })"
           class="cvx-cp-back">
            <i class="fa-solid fa-chevron-left"></i>
            @Model.CommunityName
        </a>
    }

    @* ── FORMULARIO ──────────────────────────────────────── *@
    @using (Html.BeginForm("Create", "Posts",
                new { slug = Model.CommunitySlug, modal = ViewBag.UseModalLayout == true ? "1" : "" },
                FormMethod.Post,
                new { id = "cvx-create-form", autocomplete = "off" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.CommunityId)

        @* campo oculto para MainCategoryId — lo rellena JS *@
        <input type="hidden" name="MainCategoryId" id="hidMainCat" value="" />

        @* campo oculto para tipo de post (se guarda en Content como prefijo opcional) *@
        <input type="hidden" name="PostType" id="hidPostType" value="debate" />

        <div class="cvx-cp-scroll">

            @* ── TIPO DE POST ──────────────────────────────── *@
            <p class="cvx-cp-type-label">Tipo de publicación</p>
            <div class="cvx-cp-type-row">
                <button type="button" class="cvx-cp-type-pill is-active" data-type="debate">
                    <i class="fa-solid fa-fire-flame-curved"></i> Debate
                </button>
                <button type="button" class="cvx-cp-type-pill" data-type="analisis">
                    <i class="fa-solid fa-chart-line"></i> Análisis
                </button>
                <button type="button" class="cvx-cp-type-pill" data-type="noticia">
                    <i class="fa-solid fa-satellite-dish"></i> Noticia
                </button>
                <button type="button" class="cvx-cp-type-pill" data-type="pregunta">
                    <i class="fa-regular fa-circle-question"></i> Pregunta
                </button>
            </div>

            @* ── TÍTULO ────────────────────────────────────── *@
            <div class="cvx-cp-title-wrap">
                @Html.TextBoxFor(m => m.Title, new
                {
                    @class = "cvx-cp-title-input",
                    id = "cvxTitleInput",
                    placeholder = "Título del post...",
                    maxlength = "200",
                    autocomplete = "off"
                })
                <span class="cvx-cp-title-line"></span>
                <span class="cvx-cp-title-counter" id="cvxTitleCounter">0 / 200</span>
                @Html.ValidationMessageFor(m => m.Title, "", new { @class = "cvx-cp-error" })
            </div>

            @* ── EDITOR DE CONTENIDO ───────────────────────── *@
            <div class="cvx-cp-editor-wrap">
                <div class="cvx-cp-toolbar">
                    <button type="button" class="cvx-cp-tb-btn" title="Negrita" onclick="CvxEditor.wrap('**','**')"><b>B</b></button>
                    <button type="button" class="cvx-cp-tb-btn" title="Cursiva" onclick="CvxEditor.wrap('*','*')"><i>I</i></button>
                    <div class="cvx-cp-tb-sep"></div>
                    <button type="button" class="cvx-cp-tb-btn" title="Cita" onclick="CvxEditor.prefix('> ')">
                        <i class="fa-solid fa-quote-left" style="font-size:11px"></i>
                    </button>
                    <button type="button" class="cvx-cp-tb-btn" title="Código" onclick="CvxEditor.wrap('`','`')">
                        <i class="fa-solid fa-code" style="font-size:11px"></i>
                    </button>
                    <div class="cvx-cp-tb-sep"></div>
                    <button type="button" class="cvx-cp-tb-btn" title="Enlace" onclick="CvxEditor.insertLink()">
                        <i class="fa-solid fa-link" style="font-size:11px"></i>
                    </button>
                </div>
                @Html.TextAreaFor(m => m.Content, new
                {
                    @class = "cvx-cp-content-ta",
                    id = "cvxContentTa",
                    placeholder = "Desarrolla tu post aquí... Puedes usar **negrita**, *cursiva*, `código` y > citas."
                })
                @Html.ValidationMessageFor(m => m.Content, "", new { @class = "cvx-cp-error" })
            </div>

            @* ── IMAGEN (COLAPSABLE) ───────────────────────── *@
            <button type="button" class="cvx-cp-image-toggle" id="cvxImgToggle">
                <i class="fa-solid fa-paperclip"></i> Añadir imagen (URL opcional)
                <i class="fa-solid fa-chevron-down" id="cvxImgChevron" style="margin-left:auto;font-size:0.68rem;"></i>
            </button>
            <div class="cvx-cp-image-field" id="cvxImgField">
                @Html.TextBoxFor(m => m.Image, new
                {
                    @class = "cvx-cp-image-input",
                    placeholder = "https://ejemplo.com/imagen.jpg",
                    maxlength = "500"
                })
                @Html.ValidationMessageFor(m => m.Image, "", new { @class = "cvx-cp-error" })
            </div>

            @* ── CATEGORÍAS ────────────────────────────────── *@
            @if (Model.AvailableCategories.Any())
            {
                <p class="cvx-cp-cats-label">
                    Categoría principal <span style="color:#ef4444">*</span>
                </p>
                <div class="cvx-cp-cats-row" id="cvxCatsMain">
                    @foreach (var cat in Model.AvailableCategories)
                    {
                        <button type="button"
                                class="cvx-cp-cat-chip"
                                data-cat-id="@cat.Id"
                                data-cat-mode="main"
                                style="--chip-color: @cat.ColorHex">
                            <span class="cvx-cp-cat-dot"></span>
                            @cat.Name
                        </button>
                    }
                </div>
                @Html.ValidationMessageFor(m => m.MainCategoryId, "", new { @class = "cvx-cp-error" })

                <p class="cvx-cp-cats-label" style="margin-top:14px">Categorías adicionales</p>

                <div id="cvxExtraCounter" class="cvx-cp-extra-counter">
                    Seleccionadas: <span id="cvxExtraCounterNum" class="cvx-cp-extra-counter-num">0 / 5</span>
                </div>

                <div class="cvx-cp-cats-row" id="cvxCatsExtra">
                    @foreach (var extraCat in Model.AllCategories)
                    {
                        <button type="button"
                                class="cvx-cp-cat-chip"
                                data-cat-id="@extraCat.Id"
                                data-cat-mode="extra"
                                style="--chip-color: @extraCat.ColorHex">
                            <span class="cvx-cp-cat-dot"></span>
                            @extraCat.Name
                        </button>
                        <input type="checkbox"
                               name="ExtraCategoryIds"
                               value="@extraCat.Id"
                               id="eck_@extraCat.Id"
                               style="display:none" />
                    }
                </div>
                <p class="cvx-cp-cats-hint">
                    <span>Click</span> para seleccionar — categoría principal obligatoria, adicionales opcionales
                </p>
            }
        </div>@* /cvx-cp-scroll *@

        @* ── FOOTER FIJO ───────────────────────────────────── *@
        <div class="cvx-cp-footer">
            <span class="cvx-cp-footer-left" id="cvxFooterHint">Selecciona una categoría</span>
            <div class="cvx-cp-footer-right">
                <button type="button" class="cvx-cp-btn-cancel" onclick="CvxCreatePost.cancel()">
                    Cancelar
                </button>
                <button type="submit" class="cvx-cp-btn-publish" id="cvxPublishBtn">
                    <i class="fa-solid fa-paper-plane"></i> Publicar post
                </button>
            </div>
        </div>

    }@* /form *@

</div>@* /cvx-cp-wrapper *@

<script>
    (function () {
        "use strict";

        // ── TIPO DE POST ────────────────────────────────────────
        var typePills = document.querySelectorAll(".cvx-cp-type-pill");
        var hidPostType = document.getElementById("hidPostType");
        if (hidPostType) hidPostType.value = "debate";

        typePills.forEach(function (pill) {
            pill.addEventListener("click", function () {
                typePills.forEach(function (p) { p.classList.remove("is-active"); });
                pill.classList.add("is-active");
                if (hidPostType) hidPostType.value = pill.dataset.type;
            });
        });

        // ── CONTADOR TÍTULO ─────────────────────────────────────
        var titleInput = document.getElementById("cvxTitleInput");
        var titleCounter = document.getElementById("cvxTitleCounter");

        function updateCounter() {
            var len = titleInput.value.length;
            titleCounter.textContent = len + " / 200";
            titleCounter.className = "cvx-cp-title-counter" +
                (len >= 200 ? " is-limit" : len >= 160 ? " is-near" : "");
        }
        if (titleInput) {
            titleInput.addEventListener("input", updateCounter);
            updateCounter();
        }

        // ── IMAGEN TOGGLE ───────────────────────────────────────
        var imgToggle = document.getElementById("cvxImgToggle");
        var imgField = document.getElementById("cvxImgField");
        var imgChevron = document.getElementById("cvxImgChevron");

        if (imgToggle) {
            imgToggle.addEventListener("click", function () {
                var open = imgField.classList.toggle("is-open");
                imgToggle.classList.toggle("is-open", open);
                imgChevron.style.transform = open ? "rotate(180deg)" : "";
            });
        }

        // ── CATEGORÍAS ──────────────────────────────────────────
        var MAX_EXTRA = 5;
        var hidMainCat = document.getElementById("hidMainCat");
        var footerHint = document.getElementById("cvxFooterHint");

        // ── Chips principales ────────────────────────────────────
        var mainChips = document.querySelectorAll("#cvxCatsMain .cvx-cp-cat-chip");

        function updateMainChipLabel(chip, selected) {
            if (selected) {
                chip.innerHTML =
                    '<span class="cvx-cp-cat-dot"></span>' +
                    chip.dataset.catName +
                    '<span class="cvx-cp-main-remove" title="Quitar">✕</span>';

                chip.querySelector(".cvx-cp-main-remove").addEventListener("click", function (e) {
                    e.stopPropagation();
                    chip.classList.remove("is-main");
                    chip.innerHTML = '<span class="cvx-cp-cat-dot"></span>' + chip.dataset.catName;
                    if (hidMainCat) hidMainCat.value = "";
                    if (footerHint) footerHint.textContent = "Selecciona una categoría";
                    currentMainColor = null;
                    applyGradient();
                });
            } else {
                chip.innerHTML = '<span class="cvx-cp-cat-dot"></span>' + chip.dataset.catName;
            }
        }

        mainChips.forEach(function (chip) {
            chip.dataset.catName = chip.textContent.trim();
            chip.addEventListener("click", function () {
                // Si ya está seleccionado, el click en el chip (no en la X) no hace nada
                if (chip.classList.contains("is-main")) return;

                // Deseleccionar el anterior
                mainChips.forEach(function (c) {
                    c.classList.remove("is-main");
                    updateMainChipLabel(c, false);
                });

                chip.classList.add("is-main");
                updateMainChipLabel(chip, true);
                if (hidMainCat) hidMainCat.value = chip.dataset.catId;
                if (footerHint) footerHint.textContent = "Principal: " + chip.dataset.catName;
                currentMainColor = getChipColor(chip);
                applyGradient();
            });
        });

        // ── Helpers para el orden de extras ─────────────────────
        var extraOrder = [];   // array de catId en orden de selección

        function getExtraCount() { return extraOrder.length; }

        function rebuildExtraChips() {
            // Reconstruir labels de todos los chips extra activos
            document.querySelectorAll("#cvxCatsExtra .cvx-cp-cat-chip.is-extra").forEach(function (chip) {
                var idx = extraOrder.indexOf(chip.dataset.catId);
                updateExtraChipLabel(chip, idx + 1);
            });

            // Actualizar contador
            var counter = document.getElementById("cvxExtraCounter");
            var counterNum = document.getElementById("cvxExtraCounterNum");
            if (counter && counterNum) {
                counterNum.textContent = getExtraCount() + " / " + MAX_EXTRA;
                counter.classList.toggle("is-max", getExtraCount() >= MAX_EXTRA);
            }

            // Deshabilitar chips sin seleccionar si llegamos al límite
            document.querySelectorAll("#cvxCatsExtra .cvx-cp-cat-chip:not(.is-extra)").forEach(function (chip) {
                chip.classList.toggle("is-disabled", getExtraCount() >= MAX_EXTRA);
            });

            // Gradiente: primera extra activa
            if (extraOrder.length > 0) {
                var firstChip = document.querySelector(
                    "#cvxCatsExtra .cvx-cp-cat-chip[data-cat-id='" + extraOrder[0] + "']"
                );
                currentExtraColor = firstChip ? getChipColor(firstChip) : null;
            } else {
                currentExtraColor = null;
            }
            applyGradient();
        }

        function updateExtraChipLabel(chip, orderNum) {
            // Limpiar contenido anterior (dot, número, texto, X)
            chip.innerHTML =
                '<span class="cvx-cp-extra-order">' + orderNum + '</span>' +
                chip.dataset.catName +
                '<span class="cvx-cp-extra-remove" title="Quitar">✕</span>';

            // Listener en la X
            chip.querySelector(".cvx-cp-extra-remove").addEventListener("click", function (e) {
                e.stopPropagation();
                deselecExtra(chip);
            });
        }

        function deselecExtra(chip) {
            chip.classList.remove("is-extra");
            var catId = chip.dataset.catId;
            extraOrder = extraOrder.filter(function (id) { return id !== catId; });

            // Restaurar contenido del chip a su estado base
            chip.innerHTML =
                '<span class="cvx-cp-cat-dot"></span>' +
                chip.dataset.catName;

            // Desmarcar checkbox
            var cb = document.getElementById("eck_" + catId);
            if (cb) cb.checked = false;

            rebuildExtraChips();
        }

        // ── Chips extra ──────────────────────────────────────────
        var extraChips = document.querySelectorAll("#cvxCatsExtra .cvx-cp-cat-chip");

        // Guardar el nombre original en data-cat-name para reconstruir el label
        extraChips.forEach(function (chip) {
            chip.dataset.catName = chip.textContent.trim();
        });

        extraChips.forEach(function (chip) {
            chip.addEventListener("click", function () {
                if (chip.classList.contains("is-extra")) {
                    // Ya seleccionado → deseleccionar
                    deselecExtra(chip);
                    return;
                }

                // Límite de 5
                if (getExtraCount() >= MAX_EXTRA) return;

                chip.classList.add("is-extra");
                var catId = chip.dataset.catId;
                extraOrder.push(catId);

                updateExtraChipLabel(chip, extraOrder.length);

                var cb = document.getElementById("eck_" + catId);
                if (cb) cb.checked = true;

                rebuildExtraChips();
            });
        });

        // Validar antes de submit
        var form = document.getElementById("cvx-create-form");
        if (form) {
            form.addEventListener("submit", function (e) {
                if (!hidMainCat || !hidMainCat.value) {
                    e.preventDefault();
                    if (footerHint) {
                        footerHint.textContent = "⚠ Selecciona una categoría principal";
                        footerHint.style.color = "#ef4444";
                        setTimeout(function () {
                            footerHint.textContent = "Selecciona una categoría";
                            footerHint.style.color = "";
                        }, 2500);
                    }
                    var catsSection = document.getElementById("cvxCatsMain");
                    if (catsSection) catsSection.scrollIntoView({ behavior: "smooth", block: "center" });
                }
            });
        }

        // ── GRADIENTE EN TIEMPO REAL ─────────────────────────────
        var currentMainColor = null;
        var currentExtraColor = null;

        function getChipColor(chip) {
            // color-mix no expone la variable, leemos del style inline
            var raw = chip.getAttribute("style") || "";
            var match = raw.match(/--chip-color:\s*([^;]+)/);
            return match ? match[1].trim() : null;
        }

        function hexToRgba(hex, alpha) {
            if (!hex) return "transparent";
            hex = hex.trim().replace("#", "");
            if (hex.length === 3) hex = hex[0] + hex[0] + hex[1] + hex[1] + hex[2] + hex[2];
            var r = parseInt(hex.substring(0, 2), 16);
            var g = parseInt(hex.substring(2, 4), 16);
            var b = parseInt(hex.substring(4, 6), 16);
            return "rgba(" + r + "," + g + "," + b + "," + alpha + ")";
        }

        function applyGradient() {
            var wrapper = document.querySelector(".cvx-cp-wrapper");
            if (!wrapper) return;

            if (!currentMainColor) {
                wrapper.style.backgroundImage = "";
                return;
            }

            if (!currentExtraColor) {
                wrapper.style.backgroundImage =
                    "radial-gradient(ellipse at 20% 0%, " +
                    hexToRgba(currentMainColor, 0.13) + " 0%, transparent 60%)";
                return;
            }

            wrapper.style.backgroundImage =
                "radial-gradient(ellipse at 15% 0%, " +
                hexToRgba(currentMainColor, 0.15) + " 0%, transparent 50%), " +
                "radial-gradient(ellipse at 85% 0%, " +
                hexToRgba(currentExtraColor, 0.11) + " 0%, transparent 50%)";
        }
    })
        ();
</script>